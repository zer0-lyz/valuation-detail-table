{
  "_meta": {
    "version": "2.0.0",
    "created_at": "2026-05-29",
    "description": "financial-normalizer 标准化字段 → valuation-detail-table pipeline 字段的映射规则。修复映射只需改此文件。\nv2.0.0 (2026-06-01): trial_balance 对齐胡庆余堂余额账(16 字段), 期初/期末合并为合一列; 新增 journal 节点, 完整 50 字段对齐胡庆余堂明细账(9 组辅助核算三件套 + 对方科目 + 余额/方向)。",
    "updated_at": "2026-06-01"
  },
  "trial_balance": {
    "_desc": "科目余额表字段映射",
    "field_map": {
      "account_code": "code",
      "account_name": "name",
      "currency": "currency",
      "level1_name": null,
      "level2_name": null,
      "level3_name": null,
      "opening_debit": "beginning_debit",
      "opening_credit": "beginning_credit",
      "opening_balance": "beginning_balance",
      "current_debit": "current_debit",
      "current_credit": "current_credit",
      "closing_debit": "ending_debit",
      "closing_credit": "ending_credit",
      "closing_balance": "ending_balance",
      "entity_name": "entity_name",
      "query_period": "query_period",
      "auxiliary_type": "auxiliary_type",
      "auxiliary_code": "auxiliary_code",
      "auxiliary_name": "auxiliary_name",
      "data_type": "data_type",
      "direction": "direction",
      "account_full_path": "account_full_path",
      "pnl_carryover": "pnl_carryover",
      "standard_level1": "standard_level1"
    },
    "compute_fields": {
      "balance": {
        "_desc": "期末余额:优先 ending_debit/ending_credit 分列,其次 ending_balance 合一列。\nv0.2 起如果源表只有 ending_balance 一列(带 direction),直接采用 ending_balance 即可",
        "formula_priority": [
          "ending_debit (分列, v0.1)",
          "ending_credit (分列, v0.1)",
          "ending_balance (合一列, v0.2)"
        ],
        "v0.1_formula": "ed if ed else (-ec if ec else 0)",
        "v0.2_formula": "ending_balance",
        "variables": {
          "ed": "ending_debit",
          "ec": "ending_credit",
          "ending_balance": "ending_balance (合一列, v0.2)"
        }
      },
      "direction": {
        "_desc": "余额方向:优先用源表 direction 列(v0.2),否则按 ending_debit/ending_credit 判定(v0.1)",
        "v0.2_formula": "direction (源表自带方向列,值=借/贷)",
        "v0.1_formula": "借 if ending_debit >= ending_credit else 贷"
      },
      "level": {
        "_desc": "科目级次:优先用 account_full_path 拆分层级,否则按编码长度估算",
        "v0.2_formula": "len(account_full_path.split('/')) if account_full_path else max(len(code) // 2, 1)",
        "v0.1_formula": "max(len(code) // 2, 1)"
      },
      "full_code": {
        "_desc": "完整科目路径(用于 sheet_filler 匹配 source_code_prefix)",
        "v0.2_formula": "account_full_path or code"
      },
      "standard_subject": {
        "_desc": "v0.2 新增:重分类目标科目(取 standard_level1)",
        "v0.2_formula": "standard_level1"
      }
    }
  },
  "balance_sheet": {
    "_desc": "资产负债表字段映射",
    "field_map": {
      "item_name": "label",
      "currency": null,
      "item_category": null,
      "item_direction": null,
      "closing_balance": "ending_balance",
      "opening_balance": "beginning_balance"
    },
    "compute_fields": {
      "side": {
        "_desc": "资产侧还是负债及权益侧",
        "formula": "负债及权益 if '负债' in item_category or '所有者权益' in item_category else (资产 if '资产' in item_category else '')"
      }
    }
  },

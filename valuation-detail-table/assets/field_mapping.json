  "_meta": {
    "version": "1.0.0",
    "created_at": "2026-05-29",
    "description": "financial-normalizer 标准化字段 → valuation-detail-table pipeline 字段的映射规则。修复映射只需改此文件。"
  },
  "trial_balance": {
    "_desc": "科目余额表字段映射",
    "field_map": {
      "account_code": "code",
      "account_name": "name",
      "currency": "currency",
      "level1_name": null,
      "level2_name": null,
      "level3_name": null,
      "opening_debit": "beginning_debit",
      "opening_credit": "beginning_credit",
      "opening_balance": null,
      "current_debit": "current_debit",
      "current_credit": "current_credit",
      "closing_debit": "ending_debit",
      "closing_credit": "ending_credit",
      "closing_balance": null
    },
    "compute_fields": {
      "balance": {
        "_desc": "期末余额：优先 clsing_debit/closing_credit 分列值，其次 closing_balance",
        "formula": "ed if ed and not ec else (ec if ec and not ed else (ed - ec if ed and ec else cb))",
        "variables": {
          "ed": "ending_debit",
          "ec": "ending_credit",
          "cb": null
        }
      },
      "direction": {
        "_desc": "余额方向：根据 ending_debit/ending_credit 判定",
        "formula": "借 if ending_debit >= ending_credit else 贷"
      },
      "level": {
        "_desc": "科目级次：按编码长度估算",
        "formula": "max(len(code) // 2, 1)"
      }
    }
  },
  "balance_sheet": {
    "_desc": "资产负债表字段映射",
    "field_map": {
      "item_name": "label",
      "currency": null,
      "item_category": null,
      "item_direction": null,
      "closing_balance": "ending_balance",
      "opening_balance": "beginning_balance"
    },
    "compute_fields": {
      "side": {
        "_desc": "资产侧还是负债及权益侧",
        "formula": "负债及权益 if '负债' in item_category or '所有者权益' in item_category else (资产 if '资产' in item_category else '')"
      }
    }
  },

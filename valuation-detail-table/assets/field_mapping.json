        "formula": "infer_business_content(summary)",
        "_ref": "DT-60/DT-149/DT-172/DT-179"
      },
      "settlement": {
        "_desc": "结算对象/户名(往来科目的对方单位)",
        "v0.2_formula": "customer_supplier_name (本方) or counter_customer_supplier (对方) or bank_account_name",
        "v0.1_fallback": "customer_supplier"
      },
      "occurrence_date": {
        "_desc": "发生日期(取距基准日最近的同方向凭证日期)",
        "formula": "voucher_date",
        "_ref": "DT-51/DT-178",
        "_note": "v0.1 中序时账的 date 字段,v0.2 重命名为 voucher_date 但映射到内部 date 仍为 date"

# ============================================================

# DT-153: 预生成映射文件路径（支持多个查找位置）
# skills目录可能在不同位置，需要搜索多个候选路径
_SKILLS_ROOT = _SCRIPTS_DIR.parent.parent  # ~/.workbuddy/skills/
_COL_MAP_CANDIDATES = [
    # 1. DT skill assets（最优先：sheet_col_map.json保存在这里）
    _SKILLS_ROOT / 'valuation-detail-table' / 'assets' / 'sheet_col_map.json',
    # 2. valuation-common assets
    _SCRIPTS_DIR.parent / 'assets' / 'sheet_col_map.json',
    # 3. 当前scripts目录下
    _SCRIPTS_DIR / 'sheet_col_map.json',
    # 4. 同级目录的assets
    _SCRIPTS_DIR / 'assets' / 'sheet_col_map.json',
]

_COL_MAP_PATH = None
for _candidate in _COL_MAP_CANDIDATES:
    if _candidate.exists():
        _COL_MAP_PATH = _candidate
        break

# 全局缓存：sheet_name → col_map
_COL_MAP_CACHE = None


def _load_sheet_col_map():
    """加载sheet_col_map.json预生成映射文件（DT-153强制）

    v1.0时使用_build_col_map()运行时推断列位 → 导致4大问题之"填错列"
    v2.0改为从预生成文件读取 → 消灭列位推断错误的根因

    Returns:
        dict: {sheet_name: col_map_dict}
    """
    global _COL_MAP_CACHE
    if _COL_MAP_CACHE is not None:
        return _COL_MAP_CACHE

    if _COL_MAP_PATH is None or not _COL_MAP_PATH.exists():
        # 降级：如果预生成文件不存在，回退到运行时推断
        import warnings
        warnings.warn(
            f'DT-153警告: sheet_col_map.json未找到(搜索了多个路径)，'
            f'降级到运行时列位推断。建议运行gen_col_map.py生成预映射文件。'
        )
        _COL_MAP_CACHE = {}
        return _COL_MAP_CACHE

    with open(_COL_MAP_PATH, 'r', encoding='utf-8') as f:
        data = json.load(f)

    # 从JSON提取每个Sheet的col_map
    _COL_MAP_CACHE = {}
    for sn, info in data.get('sheets', {}).items():
        _COL_MAP_CACHE[sn] = info.get('col_map', {})

    return _COL_MAP_CACHE


def _get_col_map_for_sheet(sheet_name):
    """获取指定Sheet的列映射（DT-153强制：唯一列位来源）

    Args:
        sheet_name: Sheet名称（如'3-5应收账款'）

    Returns:
        dict: {标准字段名: 列号}，如 {'book_value': 10, 'assessed_value': 11}
    """
    all_maps = _load_sheet_col_map()
    if sheet_name in all_maps:
        return all_maps[sheet_name]

    # 降级：尝试模糊匹配（去掉括号内容后匹配）
    clean_name = re.sub(r'[（(].+?[）)]', '', sheet_name).strip()
    for cached_name, cmap in all_maps.items():
        cached_clean = re.sub(r'[（(].+?[）)]', '', cached_name).strip()
        if clean_name == cached_clean:
            return cmap

    # 最终降级：返回空映射（后续校验会报错）
    return {}



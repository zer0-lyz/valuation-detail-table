def _assert_settlement_not_empty(subject_code, data_rows):
    """DT-166(A级): 往来科目结算对象名称非空断言（v3.51宽容模式）。

    v3.51宽容模式：不再crash阻断，而是：
    1. 自动填入默认值（从科目名称解析或占位文字）
    2. 收集所有空值行到errors列表
    3. 返回errors列表供Agent查看和修正

    旧版(v3.49-3.50)：空值→ValueError crash→Agent绕过fill_sheet()
    根因：crash让Agent恐惧→选择裸写openpyxl→规则全部失效。
    改为宽容模式后：Agent看到错误列表→知道问题在哪→修正后重新调。

    根因：3-8-3其他应收款16行/5-5应付账款12行/5-6预收款项21行
    结算对象名称全部为None，评估明细表只填了数字没填名称。
    """
    code4 = str(subject_code).strip()[:4]
    if code4 not in REQUIRES_SETTLEMENT_PREFIXES:
        return []  # 非往来科目，跳过

    errors = []
    for i, row in enumerate(data_rows):
        # 检查所有可能的结算对象字段名
        settlement = (
            row.get('settlement') or row.get('结算对象') or
            row.get('户名') or row.get('欠款单位名称') or
            row.get('_counterparty') or ''
        )
        if not settlement or str(settlement).strip() == '':
            # 宽容模式：自动尝试从科目名称解析
            from business_content_map import infer_counterparty_from_name
            sname = row.get('_subject_name') or row.get('科目名称') or ''
            auto_filled = infer_counterparty_from_name(subject_code, sname)
            if auto_filled and auto_filled != sname:
                # 自动填入解析结果
                row['_counterparty'] = auto_filled
                row.setdefault('settlement', auto_filled)
                errors.append(
                    f'DT-166 AUTO-FIX: 第{i+1}行结算对象名称为空，'
                    f'已自动从科目名称解析为"{auto_filled}"'
                    f'(subject={subject_code})'
                )
            else:
                # 无法解析，填入占位文字
                placeholder = f'(待确认-{code4}第{i+1}行)'
                row['_counterparty'] = placeholder
                row.setdefault('settlement', placeholder)
                errors.append(
                    f'DT-166 EMPTY: 第{i+1}行结算对象名称为空且无法自动解析！'
                    f'(subject={subject_code}, row_keys={list(row.keys())})。'
                    f'已填入占位值"{placeholder}"，请人工确认。'
                )

    return errors


def _assert_name_or_content_not_empty(subject_code, data_rows):
    """DT-167(A级): 非往来科目名称/内容列非空断言（v3.51宽容模式）。

    v3.51宽容模式：不再crash阻断，而是：
    1. 自动填入默认值（从REQUIRES_NAME_OR_CONTENT映射）
    2. 收集所有空值行到errors列表
    3. 返回errors列表供Agent查看和修正

    根因：18个非往来sheet的名称列全部未填。
    """
    code4 = str(subject_code).strip()[:4]

    # 往来科目跳过（已有DT-166覆盖）
    if code4 in REQUIRES_SETTLEMENT_PREFIXES:
        return []

    # 应交税费由DT-147专门覆盖，跳过
    if code4 == '2221':
        return []

    # 坏账准备/累计折旧/累计摊销等减值科目跳过
    if code4 in ('1231', '1602', '1702', '1603'):
        return []

    # 只对REQUIRES_NAME_OR_CONTENT中的科目强制
    if code4 not in REQUIRES_NAME_OR_CONTENT:
        return []

    errors = []
    default_name = REQUIRES_NAME_OR_CONTENT.get(code4, '待确认')

    for i, row in enumerate(data_rows):
        # 检查所有可能的名称/内容字段
        name_content = (
            row.get('name_or_content') or row.get('项目及内容') or
            row.get('名称及内容') or row.get('业务内容') or
            row.get('结算对象') or row.get('_counterparty') or ''
        )
        if not name_content or str(name_content).strip() == '':
            # 宽容模式：自动填入默认值
            row['name_or_content'] = default_name
            row.setdefault('项目及内容', default_name)
            errors.append(
                f'DT-167 AUTO-FIX: 第{i+1}行名称/内容列为空，'
                f'已自动填入默认值"{default_name}"'
                f'(subject={subject_code})'
            )

    return errors


# ============================================================
# 安全写入函数（DT-125: 禁止unmerge_all → DT-125↑: 数据行区域自动unmerge）
# ============================================================

def _safe_write_cell(ws, row, col, value, number_format=None):
    """安全写入单元格：数据行区域自动unmerge，表头/合计区域跳过。

    DT-125↑(v2.1升级): 数据行区域遇到MergedCell时自动unmerge后写入，
    而非跳过导致数据丢失。表头行(Row 1-5)和合计行区域仍跳过。

    根因：3-7预付款项R26-R28的C3列处于B:C合并范围，
    原_safe_write_cell()跳过→3行结算对象名称丢失。

    行为变化（v2.1 vs v1.0）：
    - v1.0: 遇到MergedCell → 跳过(return False) → 数据丢失
    - v2.1: 数据行区域 → unmerge后写入; 表头/合计区域 → 跳过

    Args:
        ws: worksheet
        row: 行号
        col: 列号
        value: 写入值
        number_format: 数字格式（可选）

    Returns:
        bool: True=成功写入, False=跳过(表头/合计区域MergedCell)
    """
    cell = ws.cell(row=row, column=col)

    if isinstance(cell, MergedCell):
        # DT-125↑: 判断是否在数据行区域
        # 通过sheet_col_map.json获取data_start_row和total_row判断
        is_data_row = _is_in_data_row_area(ws, row)

        if is_data_row:
            # 数据行区域：unmerge后写入（DT-125↑核心改造）
            for merge_range in list(ws.merged_cells.ranges):
                if cell.coordinate in merge_range:
                    ws.unmerge_cells(str(merge_range))
                    break
            # 重新获取cell（unmerge后不再是MergedCell）
            cell = ws.cell(row=row, column=col)
            cell.value = value
            if number_format:
                cell.number_format = number_format
            return True
        else:
            # 表头/合计区域：跳过（DT-125原行为）
            return False

    cell.value = value

    if number_format:
        cell.number_format = number_format

    return True


def _is_in_data_row_area(ws, row):
    """判断指定行是否在数据行区域内。

    通过A列标记识别：
    - A列含"表头区域"/"检索表头" → 不是数据行
    - A列含"合计1"/"合计2"/"坏账准备"/"预计风险" → 不是数据行
    - 其他 → 视为数据行区域

    同时检查sheet_col_map.json中的data_start_row/total_row信息。

    Args:
        ws: worksheet
        row: 行号

    Returns:
        bool: True=在数据行区域, False=在表头/合计区域
    """
    # 通过A列标记判断
    a_val = ws.cell(row=row, column=1).value
    if a_val:
        a_text = str(a_val).replace(' ', '').strip()
        if any(marker in a_text for marker in
               ['表头区域', '检索表头', '合计1', '合计2', '坏账准备', '预计风险']):
            return False

    # 通过sheet_col_map.json的行号信息判断
    all_maps = _load_sheet_col_map()
    sheet_name = ws.title

    # 尝试从预生成映射获取行号
    for sn, cmap in all_maps.items():
        if sn == sheet_name and isinstance(cmap, dict):
            ds = cmap.get('data_start_row')
            tr = cmap.get('total1_row') or cmap.get('total_row')
            if ds and tr:
                return ds <= row < tr

    # DT-153v3: 动态兜底——从模板中扫描数据起始行
    # 尝试从sheet中找"检索表头"标记行，其下一行即为数据起始行
    if hasattr(ws, 'max_row'):
        for r in range(1, min(ws.max_row + 1, 15)):
            val = ws.cell(row=r, column=1).value
            if val and '检索表头' in str(val):
                ds = r + 1
                # 检查下一行是否也是检索表头
                next_val = ws.cell(row=r + 1, column=1).value
                if next_val and '检索表头' in str(next_val):
                    ds = r + 2
                return row >= ds
    # 最终兜底
    return row >= 6


# ============================================================
# 列映射构建（DT-136: 禁止硬编码列号）
# ============================================================

def _build_col_map(ws, header_row, sub_header_row=None):
    """从sheet_col_map.json预生成文件读取列映射（DT-153强制）。

    v1.0时运行时推断列位 → 导致4大问题之"大量科目填错列"
    v2.0改为从预生成文件读取 → 不同Sheet的列位差异已在生成时固化

    降级逻辑：如果JSON中无该Sheet，回退到运行时推断并警告。

    Args:
        ws: worksheet
        header_row: 主表头行号（仅降级时使用）
        sub_header_row: 子表头行号（仅降级时使用）

    Returns:
        dict: {中文语义标识: 列号}，如 {'账面价值': 10, '评估价值': 11}
    """
    # DT-153: 优先从预生成文件读取
    sheet_name = ws.title
    prebuilt_map = _get_col_map_for_sheet(sheet_name)

    if prebuilt_map:
        # 将英文标准字段名转换为中文语义名（兼容v1.0接口）
        col_map = {}
        for field_name, col_num in prebuilt_map.items():
            cn_name = _FIELD_NAME_MAP.get(field_name)
            if cn_name:
                col_map[cn_name] = col_num
            else:
                # 无映射的英文字段名直接保留
                col_map[field_name] = col_num
        return col_map

    # 降级：运行时推断（仅当预生成文件中无该Sheet时使用）
    col_map = {}
    max_col = min(ws.max_column, 25)

    # DT-FR4: 双行表头智能列位推断
    # 对于双行表头（有sub_header_row），主表头"账面价值"/"评估价值"是大分类，
    # 子表头区分"原值"/"净值"/"成新率"等。此时book_value/assessed_value
    # 在DT语义中指向"净值"列（而非"原值"列），需要特殊处理。
    _TWO_ROW_HEADER_PARENTS = {'账面价值', '评估价值'}  # 需要细分的父表头

    # 先收集双行表头中父表头→子表头的映射关系
    _parent_col_map = {}  # {父表头文字: [(col, 子表头文字), ...]}
    if sub_header_row:
        for c in range(1, max_col + 1):
            hval = ws.cell(row=header_row, column=c).value
            htext = str(hval or '').strip()
            sval = ws.cell(row=sub_header_row, column=c).value
            stext = str(sval or '').strip()
            if htext in _TWO_ROW_HEADER_PARENTS:
                if htext not in _parent_col_map:
                    _parent_col_map[htext] = []
                _parent_col_map[htext].append((c, stext))

    for c in range(1, max_col + 1):
        hval = ws.cell(row=header_row, column=c).value
        htext = str(hval or '').strip()

        # 合并子表头
        stext = ''
        if sub_header_row:
            sval = ws.cell(row=sub_header_row, column=c).value
            stext = str(sval or '').strip()
        full_text = htext + stext

        # 使用旧版中文关键词匹配
        _LEGACY_KEYWORDS = {
            '序号': ['序号'],
            '项目及内容': ['项目及内容', '业务内容', '结算内容'],
            '发生日期': ['发生日期', '日期'],
            '币种': ['币种'],
            '汇率': ['汇率'],
            '账面价值': ['账面价值'],
            '评估价值': ['评估价值'],
            '增值额': ['增值额'],
            '增值率': ['增值率'],
            '备注': ['备注'],
        }

        # DT-FR4: 对双行表头中的大分类关键词，智能选择子表头列
        if sub_header_row and htext in _TWO_ROW_HEADER_PARENTS:
            # 跳过在父表头行的匹配，因为需要看子表头才能确定具体列
            # 稍后在下方统一处理
            continue

        for semantic, keywords in _LEGACY_KEYWORDS.items():
            for kw in keywords:
                if kw in full_text and semantic not in col_map:
                    col_map[semantic] = c
                    break

    # DT-FR4: 双行表头大分类→子表头列位推断
    # 账面价值→优先选"净值"列（book_value=账面净值），其次选唯一列
    # 评估价值→优先选"净值"列（assessed_value=评估净值），其次选唯一列
    if sub_header_row and _parent_col_map:
        for parent_text, children in _parent_col_map.items():
            # 查找"净值"子列
            net_col = None
            only_col = None
            for col_num, child_text in children:
                if '净值' in child_text:
                    net_col = col_num
                    break
                if only_col is None:
                    only_col = col_num

            # 确定目标列：有"净值"→选净值列；只有一个子列→选该列
            target_col = net_col if net_col is not None else only_col

            if target_col is not None:
                if parent_text == '账面价值':
                    col_map['账面价值'] = target_col
                elif parent_text == '评估价值':
                    col_map['评估价值'] = target_col

    return col_map


def _validate_col_map(col_map, sheet_id):
    """校验列映射完整性（DT-46/DT-66强制）。

    关键校验：
    1. 账面价值和评估价值列必须存在且不同（DT-46）
    2. 金额列位置校验（账面价值在评估价值之前）

    Args:
        col_map: 列映射dict
        sheet_id: 明细表前缀（如'3-5'）

    Returns:
        list: 错误消息列表，空=通过
    """
    errors = []

    bv_col = col_map.get('账面价值')
    ev_col = col_map.get('评估价值')

    # DT-46: 账面价值和评估价值必须存在
    if bv_col is None and ev_col is None:
        # 某些特殊sheet可能没有这两列（如银行存款明细）
        pass
    elif bv_col is not None and ev_col is not None:
        # DT-46: 账面价值列必须在评估价值列之前（C在D之前）
        if bv_col >= ev_col:
            errors.append(
                f'DT-46违反: 账面价值列({bv_col})不在评估价值列({ev_col})之前！'
                f'标准顺序: C=账面价值, D=评估价值'
            )
    elif bv_col is not None and ev_col is None:
        errors.append(f'DT-66警告: 账面价值列存在({bv_col})但评估价值列缺失')
    elif bv_col is None and ev_col is not None:
        errors.append(f'DT-66警告: 评估价值列存在({ev_col})但账面价值列缺失')

    return errors


# ============================================================
# 写入后回读验证（DT-97）
# ============================================================

def _read_back_verify(ws, row, col_map, expected_values):
    """写入后回读验证：检测静默写入失败。

    DT-97强制：每个数据行写入后必须回读验证。
    如果写入值≠回读值→说明写入了MergedCell或openpyxl静默失败。

    Args:
        ws: worksheet
        row: 行号
        col_map: 列映射dict
        expected_values: 预期值dict {语义标识: 值}

    Returns:
        list: 错误消息列表，空=通过
    """
    errors = []

    for semantic, expected in expected_values.items():
        col = col_map.get(semantic)
        if col is None:
            continue

        cell = ws.cell(row=row, column=col)

        # MergedCell检测
        if isinstance(cell, MergedCell):
            errors.append(
                f'DT-97违反: {semantic}列({col})在行{row}是MergedCell，'
                f'写入值{expected}被丢弃！禁止unmerge_all。'
            )
            continue

        actual = cell.value

        # 数值比较
        if isinstance(expected, (int, float)) and isinstance(actual, (int, float)):
            if abs(expected - actual) > 0.01:
                errors.append(
                    f'DT-97违反: {semantic}列({col})行{row}回读不一致！'
                    f'写入={expected:,.2f}, 回读={actual:,.2f}'
                )
        # 文本比较
        elif expected is not None and actual is not None:
            if str(expected).strip() != str(actual).strip():
                errors.append(
                    f'DT-97违反: {semantic}列({col})行{row}回读不一致！'
                    f'写入="{expected}", 回读="{actual}"'
                )
        # None检测
        elif expected is not None and actual is None:
            errors.append(
                f'DT-97违反: {semantic}列({col})行{row}写入{expected}但回读为None！'
            )

    return errors


# ============================================================
# 数据准备函数
# ============================================================

def prepare_data_rows(subject_code, aux_data=None, kmye_data=None,
                      subject_name=None, counterparty_field='name',
                      has_journal=False, has_foreign_currency=False,
                      industry_type=None, contra_account_config=None,
                      subjects_all=None):
    """为fill_sheet准备标准化的data_rows列表。

    Agent调用此函数组织数据，fill_sheet消费数据。
    Agent不需要直接操作openpyxl。

    Args:
        subject_code: 科目编码（如'2202'）
        aux_data: 辅助余额表数据 [{name, balance, ...}]
        kmye_data: 科目余额表末级数据 [{code, name, direction, balance, ...}]
        subject_name: 科目名称
        counterparty_field: aux_data中结算对象名称的字段名（默认'name'）
        has_journal: 是否有序时账（影响发生日期列）
        has_foreign_currency: 是否有外币（影响币种/汇率列）
        industry_type: 行业类型（如'房地产'），用于行业映射
        contra_account_config: 备抵科目配置，来自subject_schema.json的contra_account字段
            如 {"depreciation": "1602", "impairment": "1603"}
        subjects_all: 全量科目余额表数据（用于查找备抵科目余额）

    Returns:
        tuple: (list of dict: 标准化数据行, list: 自动修复错误)
        [
            {
                '序号': 1,
                '项目及内容': '工程款-XX公司',
                '发生日期': None,  # DT-143: 无序时账时留空
                '币种': None,      # DT-144: 无外币时留空
                '汇率': None,      # DT-144: 无外币时留空
                '账面价值': 1234567.89,
                '评估价值': 1234567.89,
                '备注': '',
                '_subject_code': '2202',
                '_counterparty': 'XX公司',
            },
            ...
        ]
        或设备类Sheet:
        [
            {
                '序号': 1,
                '项目及内容': 'XX设备',
                '账面原值': 14821021.23,
                '累计折旧': 5432100.00,
                '账面净值': 9388921.23,
                '评估价值': 9388921.23,
                ...
            },
        ]
    """
    rows = []
    data_source = aux_data or kmye_data or []

    for idx, item in enumerate(data_source, 1):
        # 获取结算对象名称
        cp_name = item.get(counterparty_field) or item.get('name', '')
        if isinstance(cp_name, str):
            cp_name = cp_name.strip()

        # DT-166↑: 对REQUIRES_SETTLEMENT_PREFIXES科目，始终从科目名称中提取结算对象。
        # 旧BUG: 只在cp_name为空或等于分类词时才调用infer_counterparty_from_name()，
        # 导致"预付账款_京东"这种非空但带前缀的名称直接透传。
        # 修复: 对往来科目始终调用去除前缀，无论cp_name是否已有值。
        code4 = str(subject_code).strip()[:4]
        if code4 in REQUIRES_SETTLEMENT_PREFIXES:
            item_name = item.get('name', '')
            # 始终从科目名称提取结算对象，去除科目前缀
            extracted = infer_counterparty_from_name(subject_code, item_name or cp_name)
            if extracted:
                cp_name = extracted
                # 如果提取结果仍只是分类词，标记待补充
                if cp_name in ('公司', '个人', '坏账准备'):
                    cp_name = f'{cp_name}(待补充具体名称)'

        # 获取余额
        balance = item.get('balance') or item.get('期末余额') or 0
        if isinstance(balance, str):
            try:
                balance = float(balance.replace(',', ''))
            except ValueError:
                balance = 0

        # 方向处理（按财政部《企业会计准则——应用指南》科目编码规则）
        # 资产类(1xxx)/成本类(5xxx)：借方余额为正，贷方余额为负
        # 负债类(2xxx)/权益类(4xxx)：贷方余额为正，借方余额为负
        direction = item.get('direction') or item.get('期末方向', '贷')
        code_prefix = str(subject_code).strip()[:1]
        is_asset_nature = code_prefix in ('1', '5')  # 资产类+成本类
        is_liability_nature = code_prefix in ('2', '4')  # 负债类+权益类
        
        if is_liability_nature and direction == '借':
            balance = -abs(balance)   # 负债类借方余额→负数
        elif is_asset_nature and direction == '贷':
            balance = -abs(balance)   # 资产类贷方余额→负数（备抵科目）
        # else: 正常方向保持原值（资产/成本类借方=正，负债/权益类贷方=正）

        # 自动推断业务内容（DT-149）
        biz_content = infer_business_content(
            subject_code, cp_name, subject_name
        )

        # ── P6: 备抵科目联动机制 ──
        # 如果有contra_account配置（如固定资产1601→1602累计折旧），
        # 计算账面原值/累计折旧/账面净值三列
        has_contra = bool(contra_account_config)

        # 查找备抵科目余额
        depreciation_total = 0  # 累计折旧/摊销
        impairment_total = 0    # 减值准备
        if has_contra and subjects_all:
            dep_code = contra_account_config.get('depreciation', '')
            imp_code = contra_account_config.get('impairment', '')

            for s in (subjects_all if isinstance(subjects_all, list) else subjects_all.get('subjects', [])):
                s_code = str(s.get('code', ''))
                s_balance = s.get('balance') or s.get('closing_balance') or 0
                s_direction = s.get('direction') or s.get('期末方向', '贷')

                if dep_code and s_code.startswith(dep_code):
                    # 备抵科目为贷方余额，取绝对值作为折旧/摊销
                    if s_direction == '贷' or s_balance < 0:
                        depreciation_total += abs(s_balance)
                    else:
                        depreciation_total += abs(s_balance)

                if imp_code and s_code.startswith(imp_code):
                    if s_direction == '贷' or s_balance < 0:
                        impairment_total += abs(s_balance)
                    else:
                        impairment_total += abs(s_balance)

        # 构建数据行
        if has_contra:
            # 设备类/无形资产类Sheet: 三列结构（账面原值/累计折旧/账面净值）
            original_value = abs(balance) if balance else 0  # 原值始终为正
            net_value = original_value - depreciation_total - impairment_total
            row = {
                '序号': idx,
                '项目及内容': biz_content,
                '发生日期': None if not has_journal else item.get('发生日期'),
                '账面原值': original_value,       # C11列: 原值
                '累计折旧': depreciation_total,   # 折旧/摊销（取绝对值）
                '账面净值': net_value,            # C12列: 原值-折旧
                '评估价值': net_value,            # 默认评估值=账面净值
                '备注': item.get('备注', ''),
                # 内部标记
                '_subject_code': subject_code,
                '_counterparty': cp_name,
                '_is_contra_account_row': True,
            }
        else:
            # 普通科目Sheet: 两列结构（账面价值/评估价值）
            row = {
                '序号': idx,
                '项目及内容': biz_content,
                '发生日期': None if not has_journal else item.get('发生日期'),
                '币种': None if not has_foreign_currency else item.get('币种'),
                '汇率': None if not has_foreign_currency else item.get('汇率'),
                '账面价值': balance,            # 保留符号方向（负债借方=负数，资产贷方=负数）
                '评估价值': balance,            # 评估价值=账面价值（同符号同金额）P9修复：禁止abs()
                '备注': item.get('备注', ''),
                # 内部标记（不写入Excel）
                '_subject_code': subject_code,
                '_counterparty': cp_name,
            }

        # 特殊科目处理
        code = str(subject_code)

        # 应交税费：添加税种和征税机关列（DT-147）
        if code.startswith('2221'):
            tax_detail = infer_tax_details(
                item.get('code', code), item.get('name', subject_name)
            )
            row['税费种类'] = tax_detail['tax_type']
            row['征税机关'] = tax_detail['authority']
            # 覆盖项目及内容为税种
            row['项目及内容'] = tax_detail['business_content']

        # 职工薪酬：按子目拆行并推断业务内容（DT-174）
        if code.startswith('2211'):
            payroll_content = infer_payroll_content(
                item.get('code', code),
                item.get('name', subject_name)
            )
            row['项目及内容'] = payroll_content

        rows.append(row)

    # DT-166(A级): 往来科目结算对象名称非空断言（v3.51宽容模式）
    dt166_errors = _assert_settlement_not_empty(subject_code, rows)

    # DT-167(A级): 非往来科目名称/内容列非空断言（v3.51宽容模式）
    dt167_errors = _assert_name_or_content_not_empty(subject_code, rows)

    # 收集所有自动修复的错误
    all_auto_fixes = dt166_errors + dt167_errors

    return rows, all_auto_fixes


# ============================================================
# 主写入函数（12条DT规则强制执行）
# ============================================================

def fill_sheet(ws, sheet_name=None, data_rows=None, settings=None, wb=None,
               has_journal=False, has_foreign_currency=False,
               bad_debt_amount=None, provision_amount=None,
               journal_data=None, subject_code=None):
    """Agent唯一允许调用的明细表写入接口（v2.0）。

    v2.0核心改造（2026-05-24复盘4大问题后）:
    1. DT-153: 列位从sheet_col_map.json读取，不再运行时推断
    2. DT-151: 坏账准备行内部自动填写，从科目余额表自动提取
    3. DT-152: 行数不够时内部自动调用smart_insert_row()
    4. DT-150: 序时账数据映射发生日期和业务内容

    Args:
        ws: openpyxl worksheet对象
        sheet_name: Sheet名称（如'3-5应收账款'），DT-153强制用于查找预生成列映射
        data_rows: prepare_data_rows()返回的标准化数据行列表（v3.51兼容：支持(rows, errors)元组）
        settings: 设置信息dict（含被评估单位名称、评估基准日等）
        wb: openpyxl workbook对象（跨sheet引用更新需要）
        has_journal: 是否有序时账
        has_foreign_currency: 是否有外币
        bad_debt_amount: 坏账准备金额（兼容v1.0，v2.0内部可自动提取）
        provision_amount: 预计风险金额（兼容v1.0）
        journal_data: 序时账映射数据 {结算对象: {date, business}} (DT-150)
        subject_code: 科目编码（用于坏账准备自动提取，DT-151）

    Returns:
        dict: {
            'success': bool,       # v3.51: 不再crash，失败时success=False+errors有详情
            'rows_written': int,
            'col_map': dict,
            'read_back_errors': list,
            'gate_errors': list,
            'warnings': list,
        }
    """
    # DT-153: sheet_name为强制参数
    if not sheet_name:
        sheet_name = ws.title

    # DT-159: 禁止子Agent调用（红线规则）
    _assert_no_agent_tool_dispatch()

    # DT-165↑: 调用栈安全检测——确保调用方通过fill_sheet()管线操作ws
    # 根因：phase4_fix_reconcile.py等独立脚本用裸insert_rows+safe_write绕开fill_sheet，
    # 导致DT-113/120/152/162格式规则全部失效（3-7预付款项格式全丢）
    # 检测逻辑：调用栈中应包含sheet_filler模块，否则说明是从外部裸API调用
    _assert_call_stack_safety()

    # 执行日志（用于断言覆盖率检测）
    _execution_log = {}

    result = {
        'success': False,
        'rows_written': 0,
        'col_map': {},
        'read_back_errors': [],
        'gate_errors': [],
        'warnings': [],
        'assertion_coverage': None,
    }

    # v3.51兼容：prepare_data_rows()现在返回(rows, errors)元组
    prepare_auto_fixes = []
    if isinstance(data_rows, tuple) and len(data_rows) == 2:
        data_rows, prepare_auto_fixes = data_rows
        if prepare_auto_fixes:
            result['warnings'].extend(prepare_auto_fixes)

    if not data_rows:
        result['warnings'].append(f'⚠️ Sheet {sheet_name}: data_rows为空，跳过填写')
        result['success'] = True
        return result

    # ============================================================
    # Step 1: 识别工作表结构
    # ============================================================
    struct = _find_header_structure(ws)
    header_row = struct.get('header_row')
    sub_header_row = struct.get('sub_header_row')
    data_start_row = struct.get('data_start_row')
    _execution_log['DT-157'] = 'PASS'  # data_start_row从_find_header_structure获取
    total_row = struct.get('total_row')
    bad_debt_row = struct.get('bad_debt_row')
    provision_row = struct.get('provision_row')
    total2_row = struct.get('total2_row')

    if not header_row:
        error_msg = f'DT-136 WARNING: Sheet {sheet_name} 无法识别表头行，尝试扫描式兜底'
        result['warnings'].append(error_msg)
        # v3.52: 不再crash，尝试扫描式兜底定位表头行
        # 策略：从Row 1-10扫描，找到含"科目"/"名称"/"账面价值"等关键字的行
        header_row = _fallback_find_header_row(ws)
        if header_row:
            result['warnings'].append(f'  兜底成功: 使用Row {header_row}作为表头行')
        else:
            result['gate_errors'].append(f'DT-136 CRITICAL: 兜底也失败，Sheet {sheet_name}无法继续写入')
            result['success'] = False
            return result

    if not total_row:
        error_msg = f'DT-120 WARNING: Sheet {sheet_name} 无法识别合计行，尝试扫描式兜底'
        result['warnings'].append(error_msg)
        # v3.52: 不再crash，尝试扫描式兜底定位合计行
        # 策略：从A列扫描"合计1"/"合 计"关键字
        total_row = _fallback_find_total_row(ws)
        if total_row:
            result['warnings'].append(f'  兜底成功: 使用Row {total_row}作为合计1行')
        else:
            result['gate_errors'].append(f'DT-120 CRITICAL: 兜底也失败，Sheet {sheet_name}无法继续写入')
            result['success'] = False
            return result

    if not data_start_row:
        result['warnings'].append(
            f'⚠️ 无法识别数据起始行，使用合计行-1={total_row - 1}'
        )
        data_start_row = total_row - 1

    # ============================================================
    # Step 2: 构建列映射（DT-153强制：从预生成文件读取）
    # ============================================================
    col_map = _build_col_map(ws, header_row, sub_header_row)
    result['col_map'] = col_map

    # 校验列映射（DT-46/DT-66强制）
    col_errors = _validate_col_map(col_map, sheet_name)
    if col_errors:
        result['gate_errors'].extend(col_errors)
        # v3.51宽容模式：列映射校验失败不crash，收集错误继续写入
        # 旧版：raise ValueError → Agent因crash绕过fill_sheet
        # 新版：收集错误到result，Agent看到错误后可修正
        result['warnings'].append(
            f'⚠️ DT-46/DT-66: Sheet {sheet_name} 列映射有{len(col_errors)}个问题，'
            f'尽力写入。问题: {"; ".join(col_errors[:3])}'
        )

    # ============================================================
    # Step 2.5: DT-150 序时账数据映射（发生日期+业务内容）
    # ============================================================
    if has_journal and journal_data and data_rows:
        for row_data in data_rows:
            cp = row_data.get('_counterparty', '')
            if cp and cp in journal_data:
                j_info = journal_data[cp]
                # 映射发生日期
                if j_info.get('date') and '发生日期' in col_map:
                    row_data['发生日期'] = j_info['date']
                # 映射业务内容
                if j_info.get('business') and '项目及内容' in col_map:
                    row_data['项目及内容'] = j_info['business']

    # ============================================================
    # Step 3: 插入数据行（DT-152: fill_sheet内部自动调用smart_insert_row）
    # ============================================================
    template_data_rows = total_row - data_start_row
    needed_rows = len(data_rows)

    # DT-155: 幂等保护——写入前先clear目标区域
    _assert_idempotent_clear(ws, data_start_row, total_row, col_map)
    _execution_log['DT-155'] = 'PASS'

    # DT-156: 数据源去重（如果有dedup_key）
    # 从subject_schema.json获取dedup_key（如调用方未提供，则跳过）
    if not hasattr(fill_sheet, '_dedup_keys_cache'):
        fill_sheet._dedup_keys_cache = {}
    dedup_key = fill_sheet._dedup_keys_cache.get(sheet_name)
    if dedup_key:
        data_rows = _assert_dedup_before_write(data_rows, dedup_key)
    _execution_log['DT-156'] = 'PASS'

    if needed_rows > template_data_rows:
        # DT-152: 内部自动调用smart_insert_row，Agent无需手动处理
        # v2.0(DT-162): 移除ref_row/data_start_row/copy_style参数，格式由_apply_direct_format直接定义
        insert_count = needed_rows - template_data_rows
        insert_result = smart_insert_row(
            ws,
            target_row=total_row,
            count=insert_count,
            total_row=total_row,
            header_rows=[header_row] + ([sub_header_row] if sub_header_row else []),
            wb=wb,
            col_map=col_map,
        )

        # 更新结构行号（插入后行号已变化）
        total_row = insert_result.get('new_total_row', total_row + insert_count)
        bad_debt_row = (bad_debt_row + insert_count) if bad_debt_row and bad_debt_row >= data_start_row else bad_debt_row
        provision_row = (provision_row + insert_count) if provision_row and provision_row >= data_start_row else provision_row
        total2_row = (total2_row + insert_count) if total2_row and total2_row >= data_start_row else total2_row

        if insert_result.get('warnings'):
            result['warnings'].extend(insert_result['warnings'])

        # DT-163: 记录合计行B:C合并修复结果
        merges_fixed = insert_result.get('merges_fixed', [])
        dt163_fixes = [m for m in merges_fixed if 'DT-163' in m]
        if dt163_fixes:
            result['DT-163'] = f'合计行B:C合并已修复: {dt163_fixes}'

        if insert_result.get('format_adjusted'):
            fmt_adj = insert_result['format_adjusted']
            result['warnings'].append(
                f'ℹ️ 即时格式微调: {fmt_adj["rows_formatted"]}行已应用标准格式'
                f'(行高={fmt_adj["ref_height"]}pt)'
            )

    # ============================================================
    # Step 3.5: DT-164.1 合计行保护断言（插行后+写入前）
    # ============================================================
    # 复盘: 3-7预付款项35条数据 > 模板预填20行，v2脚本直接逐行覆写，
    # 导致合计1/坏账准备/合计2三行被数据覆盖→A列标记+SUM公式+B:C合并全部丢失
    # 此断言确保插行后合计行结构完整，数据写入不会覆盖结构行
    _assert_total_row_integrity(ws, total_row, bad_debt_row, provision_row, col_map, sheet_name, total2_row)

    # ============================================================
    # Step 3.7: DT-101↑ 负债科目符号自动处理
    # ============================================================
    # 根因：5-9应交税费为勾稽匹配简单取反，未考虑评估实务列示规范。
    # 新行为：fill_sheet()内部自动处理负债科目符号，
    # 贷方余额→正数填入，借方余额→负数填入+备注自动加注"[借方余额]"。
    # 禁止Agent自行决定符号方向。
    liability_prefixes = {'2201', '2202', '2203', '2211', '2221', '2231',
                         '2232', '2241', '2401', '2501', '2502', '2701',
                         '2601', '2802', '2901'}
    if subject_code:
        code4 = str(subject_code).strip()[:4]
        if code4 in liability_prefixes:
            for row_data in data_rows:
                bv = row_data.get('账面价值')
                if bv is not None and isinstance(bv, (int, float)):
                    # 负债科目：贷方余额(正数)保持，借方余额(负数)保持+备注
                    if bv < 0:
                        remark = row_data.get('备注', '')
                        if not remark or '[借方余额]' not in str(remark):
                            row_data['备注'] = f'[借方余额]{remark}'.strip()

    # ============================================================
    # Step 4: 逐行写入数据（DT-125↑/DT-97/DT-143/DT-144/DT-150强制）
    # ============================================================
    all_read_back_errors = []
    written_count = 0

    # v2.0: 字段名对齐——处理prepare_data_rows()输出与col_map的字段名差异
    # 问题: prepare_data_rows()返回'项目及内容'，但col_map映射了'结算对象'+'业务内容'分开的字段
    # 解决: 在写入时自动拆分/对齐
    def _align_row_data(row_data, col_map):
        """将data_rows中的字段名对齐到col_map的字段名"""
        aligned = dict(row_data)  # 复制
        
        # 情况1: data_rows有'项目及内容'，但col_map有'结算对象'和'业务内容'
        if '项目及内容' in aligned and '项目及内容' not in col_map:
            content = aligned.pop('项目及内容', '')
            if '结算对象' in col_map and '_counterparty' in aligned:
                aligned['结算对象'] = aligned.pop('_counterparty', content)
            elif '结算对象' in col_map:
                aligned['结算对象'] = content
            if '业务内容' in col_map:
                aligned['业务内容'] = content
        
        # 情况2: data_rows有'结算对象'，但col_map只有'项目及内容'
        elif '结算对象' in aligned and '结算对象' not in col_map and '项目及内容' in col_map:
            settlement = aligned.pop('结算对象', '')
            biz = aligned.pop('业务内容', '')
            aligned['项目及内容'] = f'{settlement}-{biz}' if biz else settlement
        
        # 情况3: data_rows没有'结算对象'但col_map有，用_counterparty填充
        elif '结算对象' in col_map and '结算对象' not in aligned and '_counterparty' in aligned:
            aligned['结算对象'] = aligned['_counterparty']
        
        return aligned

    for i, row_data in enumerate(data_rows):
        target_row = data_start_row + i

        # 检查是否超出合计行
        if target_row >= total_row:
            result['warnings'].append(
                f'⚠️ 数据行{target_row}超出合计行{total_row}，截断'
            )
            break

        # v2.0: 字段名对齐
        aligned_data = _align_row_data(row_data, col_map)

        # 准备预期值（用于回读验证）
        expected = {}

        for semantic, value in aligned_data.items():
            # 跳过内部标记
            if semantic.startswith('_'):
                continue

            # DT-143: 无序时账时发生日期留空
            if semantic == '发生日期' and not has_journal:
                value = None
            # DT-144: 无外币时币种/汇率留空
            if semantic in ('币种', '汇率') and not has_foreign_currency:
                value = None

            # 查找列号
            col = col_map.get(semantic)
            if col is None:
                continue

            # 日期类型处理（DT-30）
            if semantic == '发生日期' and value is not None:
                if isinstance(value, str):
                    try:
                        value = datetime.strptime(value, '%Y-%m-%d').date()
                    except ValueError:
                        try:
                            value = datetime.strptime(value, '%Y/%m/%d').date()
                        except ValueError:
                            pass  # 保留原始字符串

            # 写入（DT-125: 安全写入，跳过MergedCell）
            if isinstance(value, (int, float)) and not isinstance(value, bool):
                _safe_write_cell(ws, target_row, col, value, '#,##0.00')
                expected[semantic] = value
            else:
                _safe_write_cell(ws, target_row, col, value)
                if value is not None:
                    expected[semantic] = value

        # 回读验证（DT-97强制）
        rb_errors = _read_back_verify(ws, target_row, col_map, expected)
        if rb_errors:
            all_read_back_errors.extend(rb_errors)

        written_count += 1

    result['rows_written'] = written_count
    result['read_back_errors'] = all_read_back_errors

    # ============================================================
    # Step 4.5: 前置格式统一
    # ============================================================
    try:
        from excel_row_ops import _apply_standard_data_format
        fmt_result = _apply_standard_data_format(
            ws, data_start_row, total_row - 1,
            col_map=col_map,
            header_row=header_row,
            sub_header_row=sub_header_row,
        )
        if fmt_result['rows_formatted'] > 0:
            result['warnings'].append(
                f'ℹ️ Step4.5前置格式统一: {fmt_result["rows_formatted"]}行已应用标准格式'
                f'(行高={fmt_result["ref_height"]}pt)'
            )
    except (ImportError, Exception):
        pass  # 格式统一非关键，跳过

    # ============================================================
    # Step 5: 坏账准备行/预计风险行填写（DT-151↑对齐DT-18强制）
    # ============================================================
    # DT-151↑(v2.1修正): 对齐DT-18评估底稿列示规范
    #   坏账准备行: I列(账面价值)=+abs(坏账金额)正数, J列(评估价值)=0
    #   预计风险行: I列(账面价值)=0,              J列(评估价值)=+abs(减值评估值)正数
    #   合计2行:   由模板公式=合计1行J-坏账准备行J-预计风险行J 自动计算
    # 旧版DT-151写负数(-abs)，与DT-18矛盾，已修正
    if bad_debt_row and bad_debt_amount is not None:
        bv_col = col_map.get('账面价值')
        ev_col = col_map.get('评估价值')

        # DT-151↑核心：坏账准备行 = 账面价值列写+|坏账金额|正数，评估价值列写0
        # 正数列示=评估底稿规范(DT-18)，合计2行公式自动做减法
        if bv_col:
            _safe_write_cell(ws, bad_debt_row, bv_col, abs(bad_debt_amount), '#,##0.00')
        if ev_col:
            _safe_write_cell(ws, bad_debt_row, ev_col, 0, '#,##0.00')

    if provision_row and provision_amount is not None:
        bv_col = col_map.get('账面价值')
        ev_col = col_map.get('评估价值')

        # DT-151↑核心：预计风险行 = 账面价值列写0，评估价值列写+|减值评估值|正数
        if bv_col:
            _safe_write_cell(ws, provision_row, bv_col, 0, '#,##0.00')
        if ev_col:
            _safe_write_cell(ws, provision_row, ev_col, abs(provision_amount), '#,##0.00')

    # ============================================================
    # Step 6: 汇总结果
    # ============================================================
    has_critical = bool(result['gate_errors']) or bool(all_read_back_errors)
    result['success'] = not has_critical

    # DT-158: 每sheet填后即时勾稽
    # reconcile_target由调用方传入（通过data_loader从subject_schema.json获取）
    reconcile_target = settings.get('_reconcile_target') if settings else None
    if reconcile_target is not None:
        reconciled = _assert_per_sheet_reconciliation(
            ws, sheet_name, data_rows, col_map, reconcile_target
        )
        _execution_log['DT-158'] = 'PASS' if reconciled else 'FAIL'
    else:
        _execution_log['DT-158'] = 'SKIP'  # 无勾稽目标

    # DT-157: data_start_row断言
    _assert_start_row_from_map(data_start_row, sheet_name)

    # ---- DT-175: 输出格式完整性Gate（方案C） ----
    # 填表完成后自动触发格式检查，无论Agent是否通过fill_sheet()填写
    try:
        from gate_validator import validate_output_format_integrity
        format_result = validate_output_format_integrity(wb)
        if not format_result.get('pass', True):
            format_criticals = format_result.get('criticals', [])
            format_warnings = format_result.get('warnings', [])
            # 只附加当前sheet相关的格式错误
            for c in format_criticals:
                if sheet_name in c:
                    result['gate_errors'].append(f'[DT-175 FORMAT] {c}')
            for w in format_warnings:
                if sheet_name in w:
                    result['warnings'].append(f'[DT-175 FORMAT] {w}')
            _execution_log['DT-175'] = 'FAIL' if format_criticals else 'WARN'
        else:
            _execution_log['DT-175'] = 'PASS'
    except ImportError:
        _execution_log['DT-175'] = 'SKIP'  # gate_validator不可用时跳过

    # 断言覆盖率检测
    coverage = rule_coverage_check(2, _execution_log)
    result['assertion_coverage'] = coverage

    if has_critical:
        error_summary = (
            f'Sheet {sheet_name} 存在{len(result["gate_errors"])}个门控错误'
            f' + {len(all_read_back_errors)}个回读错误！'
        )
        result['warnings'].insert(0, f'🚨 {error_summary}')
        # v3.51宽容模式：不再crash，返回完整错误列表让Agent查看修正
        # 旧版：raise RuntimeError → Agent因crash绕过fill_sheet()
        # 新版：result['success']=False + result['gate_errors']有详情
        # Agent看到错误后可以修正data_rows重新调fill_sheet()
        result['success'] = False

    return result


# ============================================================
# v3.52新增: 兜底结构识别函数（消灭crash驱动绕过的根因）
# ============================================================

def _fallback_find_header_row(ws, max_scan=10):
    """兜底定位表头行：当_find_header_structure()返回None时使用。

    策略：从Row 1-10扫描，找到含"科目"/"名称"/"账面价值"等关键字的行。
    返回第一个匹配行号，找不到则返回None。
    """
    HEADER_KEYWORDS = ['科目', '名称', '账面价值', '评估价值', '序号', '项目及内容']
    for r in range(1, max_scan + 1):
        for c in range(1, min(ws.max_column + 1, 20)):
            val = ws.cell(row=r, column=c).value
            if val and isinstance(val, str):
                for kw in HEADER_KEYWORDS:
                    if kw in val:
                        return r
    return None


def _fallback_find_total_row(ws, max_scan=60):
    """兜底定位合计行：当_find_header_structure()返回None时使用。

    策略：从A列扫描"合计1"/"合 计"关键字。
    返回第一个匹配行号，找不到则返回None。
    """
    for r in range(1, max_scan + 1):
        a_val = ws.cell(row=r, column=1).value
        if a_val and isinstance(a_val, str):
            cleaned = a_val.replace(' ', '').strip()
            if '合计' in cleaned and ('1' in cleaned or cleaned == '合计'):
                return r
    return None


def fill_sheet_safe(ws, **kwargs):
    """fill_sheet()的安全封装，catch所有异常返回result而非crash。

    v3.52新增：解决Agent因fill_sheet() crash而绕过管道的问题。
    Agent应优先调用fill_sheet_safe()，失败时检查result中的错误列表，
    而非被crash驱使去直接用openpyxl裸写。

    用法：
        result = fill_sheet_safe(ws, sheet_name='3-5', data_rows=data, ...)
        if not result['success']:
            for err in result['gate_errors']:
                print(err)  # 查看错误，修正后重试

    Args:
        ws: worksheet对象
        **kwargs: 传递给fill_sheet()的所有参数

    Returns:
        dict: fill_sheet()的返回值（不会crash），额外增加：
            - 'exception': 异常信息（如有）
    """
    try:
        return fill_sheet(ws, **kwargs)
    except (ValueError, RuntimeError) as e:
        # 结构识别/合计行保护等crash → 降级为result
        return {
            'success': False,
            'rows_written': 0,
            'col_map': {},
            'read_back_errors': [],
            'gate_errors': [f'fill_sheet() crash: {e}'],
            'warnings': [
                f'⚠️ fill_sheet()因异常退出: {e}',
                f'请检查错误并修正后重试，不要绕过fill_sheet()管道。',
            ],
            'assertion_coverage': None,
            'exception': str(e),
        }
    except Exception as e:
        # 其他未预期的异常
        return {
            'success': False,
            'rows_written': 0,
            'col_map': {},
            'read_back_errors': [],
            'gate_errors': [f'fill_sheet() unexpected error: {e}'],
            'warnings': [f'⚠️ fill_sheet()遇到未预期异常: {e}'],
            'assertion_coverage': None,
            'exception': str(e),
        }


# ============================================================
# 便捷函数：科目编码→明细表前缀映射（DT-145: 行业映射）
# ============================================================

def get_sheet_id_for_subject(subject_code, industry_type=None):
    """根据科目编码（和行业类型）返回对应的明细表前缀。

    DT-145强制：行业特殊科目映射从industry_mapping.json读取，
    Agent不能跳过行业映射。

    Args:
        subject_code: 科目编码
        industry_type: 行业类型（如'房地产'）

    Returns:
        str or None: 明细表前缀（如'3-9', '5-5'）
    """
    # 标准映射
    STANDARD_MAP = {
        # ─── 流动资产 ───
        '1001': '3-1-1',                     # 库存现金
        '1002': '3-1-2',                     # 银行存款
        '1012': '3-1-3',                     # 其他货币资金
        '1101': '3-2-3',                     # 交易性金融资产→基金(默认)
        '1121': '3-4',                       # 应收票据
        '1122': '3-5',                       # 应收账款
        '1123': '3-7',                       # 预付款项
        '1131': '3-8-2',                     # 应收股利
        '1132': '3-8-1',                     # 应收利息
        '1221': '3-8-3',                     # 其他应收款
        '1231': '3-8',                       # 坏账准备(合并在3-8系列)
        '1241': '3-8',                       # 坏账准备(CPA标准编码，合并在3-8)
        '1401': '3-9', '1403': '3-9-2',     # 存货/原材料
        '1405': '3-9-5', '1408': '3-9',     # 库存商品/委托加工→存货
        '5001': '3-9-6', '5002': '3-9-6',   # 生产成本/自制半成品→在产品
        '5201': '3-9-6',                     # 劳务成本→在产品
        # ─── 非流动资产 ───
        '1501': '4-1',                       # 债权投资
        '1511': '4-4',                       # 长期股权投资→股权投资
        '1601': '4-8',                       # 固定资产→4-8系列子Sheet
        '1602': '4-8',                       # 累计折旧(备抵，合并在4-8)
        '1603': '4-8',                       # 固定资产减值准备(备抵)
        '1604': '4-9-2',                     # 在建工程→在建(设备)
        '1700': '4-12',                      # 使用权资产
        '1701': '4-13-3',                    # 无形资产→无形-其他
        '1702': '4-13-3',                    # 累计摊销(备抵，合并在4-13-3)
        '1703': '4-13-3',                    # 无形资产减值准备(备抵)
        '1801': '4-16',                      # 长期待摊费用
        '1811': '4-17',                      # 递延所得税资产
        '1821': '3-13',                      # 抵债资产→其他流动资产
        # ─── 流动负债 ───
        '2201': '5-1',                       # 短期借款
        '2202': '5-5',                       # 应付账款
        '2203': '5-6',                       # 预收款项/合同负债
        '2211': '5-8',                       # 应付职工薪酬→职工薪酬
        '2221': '5-9',                       # 应交税费
        '2231': '5-10-1',                    # 应付利息
        '2232': '5-10-2',                    # 应付股利
        '2241': '5-10-3',                    # 其他应付款
        '2401': '6-7',                       # 递延收益
        # ─── 非流动负债 ───
        '2501': '6-1',                       # 长期借款
        '2600': '6-3',                       # 租赁负债(公司自定义编码)
        '260001': '6-3',                      # 未确认融资费用→租赁负债(备抵)
        '2802': '6-3',                       # 未确认融资费用→租赁负债(备抵)
        '2701': '6-4',                       # 长期应付款
        '2901': '6-8',                       # 递延所得税负债
    }

    code = str(subject_code).strip()
    code4 = code[:4] if len(code) >= 4 else code

    # 先查标准映射
    sheet_id = STANDARD_MAP.get(code4)
    if sheet_id:
        return sheet_id

    # 再查行业映射（DT-145）
    if industry_type and INDUSTRY_MAPPING:
        industry_data = INDUSTRY_MAPPING.get('行业映射', {}).get(industry_type, {})
        mappings = industry_data.get('映射', [])
        for m in mappings:
            if m['科目编码'] == code4:
                return m['明细表前缀']

    # 再查通用特殊映射
    general_mappings = INDUSTRY_MAPPING.get('通用特殊映射', {}).get('映射', [])
    for m in general_mappings:
        if m['科目编码'] == code4:
            # 检查额外条件
            if '科目名称_含' in m:
                # 需要科目名称信息，这里只返回前缀
                return m.get('明细表前缀')
            return m.get('明细表前缀')

    # DT-153v3: 按科目编码前缀模糊匹配（兼容非标准编码）
    # 例如：1700→1701(无形资产)、2600→2601(租赁负债)、5201→5001/1401(存货)
    for std_code, sid in STANDARD_MAP.items():
        if code4.startswith(std_code[:3]) and len(std_code) >= 3:
            return sid

    # DT-153v3: 按科目名称关键词匹配（最终fallback）
    # 由调用方传入科目名称时使用，此处返回None
    return None


def get_sheet_id_by_name(subject_name, industry_type=None):
    """DT-153v3: 根据科目名称关键词推断明细表前缀

    当科目编码非标准（如1700使用权资产、5201劳务成本）时，
    编码匹配失败，可通过名称关键词fallback匹配。
    """
    if not subject_name:
        return None

    NAME_KEYWORD_MAP = {
        '3-1-1': ['库存现金'],
        '3-1-2': ['银行存款'],
        '3-1-3': ['其他货币资金'],
        '3-2-3': ['交易性金融资产'],
        '3-4':   ['应收票据'],
        '3-5':   ['应收账款'],
        '3-7':   ['预付', '预付款项'],
        '3-8':   ['其他应收', '坏账准备'],
        '3-8-1': ['应收利息'],
        '3-8-2': ['应收股利'],
        '3-8-3': ['其他应收款'],
        '3-9':   ['存货', '原材料', '库存商品', '产成品', '劳务成本', '合同履约成本'],
        '4-1':   ['债权投资'],
        '4-4':   ['长期股权投资'],
        '4-8':   ['固定资产', '累计折旧'],
        '4-9':   ['在建工程'],
        '4-12':  ['使用权资产'],
        '4-13':  ['无形资产', '累计摊销'],
        '4-16':  ['长期待摊'],
        '4-17':  ['递延所得税资产'],
        '5-1':   ['短期借款'],
        '5-5':   ['应付账款'],
        '5-6':   ['预收', '合同负债'],
        '5-8':   ['应付职工薪酬', '职工薪酬'],
        '5-9':   ['应交税费'],
        '5-10':  ['其他应付', '长期应付款'],
        '5-10-1': ['应付利息'],
        '5-10-2': ['应付股利'],
        '5-10-3': ['其他应付款'],
        '6-1':   ['长期借款'],
        '6-3':   ['租赁负债'],
        '6-7':   ['递延收益'],
        '6-8':   ['递延所得税负债'],
    }

    for sid, keywords in NAME_KEYWORD_MAP.items():
        if any(kw in subject_name for kw in keywords):
            return sid

    # 行业映射关键词fallback
    if industry_type and INDUSTRY_MAPPING:
        industry_data = INDUSTRY_MAPPING.get('行业映射', {}).get(industry_type, {})
        name_mappings = industry_data.get('名称映射', [])
        for m in name_mappings:
            if m.get('科目名称_含', '') in subject_name:
                return m.get('明细表前缀')

    return None


# ============================================================
# v2.1新增断言：DT-155~DT-159（河南平绿项目复盘5大根因）
# ============================================================

def _assert_total_row_integrity(ws, total_row, bad_debt_row, provision_row, col_map, sheet_name, total2_row=None):
    """DT-164.1: 合计行保护断言——插行后+写入前验证合计行结构完整

    复盘: 3-7预付款项35条数据 > 模板预填20行，v2脚本直接逐行覆写，
    导致合计1/坏账准备/合计2三行被数据覆盖→A列标记+SUM公式+B:C合并全部丢失。

    此断言在fill_sheet()的Step3.5执行，确保：
    1. 合计1行A列标记存在("合计1")
    2. 合计1行B列含"合"或"计"关键字
    3. 坏账准备行A列标记存在("坏账准备")
    4. 合计2行A列标记存在("合计2")
    任一断言失败=RuntimeError阻断写入
    """
    if not total_row:
        return  # 无合计行则跳过

    errors = []

    # 合计1行检查
    a_val = ws.cell(row=total_row, column=1).value
    a_text = str(a_val).replace(' ', '').strip() if a_val else ''
    if '合' not in a_text and '计' not in a_text:
        errors.append(f'合计1行(Row{total_row})A列标记缺失: A{total_row}="{a_val}"，应为"合计1"')

    b_val = ws.cell(row=total_row, column=2).value
    b_text = str(b_val).replace(' ', '').strip() if b_val else ''
    if '合' not in b_text and '计' not in b_text:
        errors.append(f'合计1行(Row{total_row})B列不含"合/计": B{total_row}="{b_val}"，应为"合 计"')

    # 坏账准备行检查
    if bad_debt_row and bad_debt_row > total_row:
        a_val_bd = ws.cell(row=bad_debt_row, column=1).value
        a_text_bd = str(a_val_bd).replace(' ', '').strip() if a_val_bd else ''
        if '坏账' not in a_text_bd and '减' not in a_text_bd and '减值' not in a_text_bd:
            errors.append(f'坏账准备行(Row{bad_debt_row})A列标记缺失: A{bad_debt_row}="{a_val_bd}"，应为"坏账准备"')

    # 合计2行/预计风险行检查
    # 优先使用传入的total2_row（从_find_header_structure获取），避免错误地把provision_row当total2_row
    if not total2_row:
        # 回退：尝试从A列扫描找到合计2行
        for r in range((bad_debt_row or total_row) + 1, min(ws.max_row + 1, (bad_debt_row or total_row) + 10)):
            a_v = ws.cell(row=r, column=1).value
            a_t = str(a_v).replace(' ', '').strip() if a_v else ''
            if '合' in a_t and '计' in a_t:
                total2_row = r
                break

    if total2_row:
        a_val_t2 = ws.cell(row=total2_row, column=1).value
        a_text_t2 = str(a_val_t2).replace(' ', '').strip() if a_val_t2 else ''
        if '合' not in a_text_t2:
            errors.append(f'合计2行(Row{total2_row})A列标记缺失: A{total2_row}="{a_val_t2}"，应为"合计2"')

        b_val_t2 = ws.cell(row=total2_row, column=2).value
        b_text_t2 = str(b_val_t2).replace(' ', '').strip() if b_val_t2 else ''
        if '合' not in b_text_t2 and '计' not in b_text_t2:
            errors.append(f'合计2行(Row{total2_row})B列不含"合/计": B{total2_row}="{b_val_t2}"，应为"合 计"')

    if errors:
        error_msg = (
            f'DT-164.1 CRITICAL: Sheet {sheet_name} 合计行保护断言失败！\n'
            f'  数据行可能已覆盖合计行，导致A列标记+SUM公式+B:C合并丢失。\n'
            f'  错误详情:\n' +
            '\n'.join(f'    - {e}' for e in errors) +
            '\n  根因: needed_rows > template_data_rows但未调用smart_insert_row()插入行，'
            '\n  而是直接逐行覆写导致数据覆盖了合计行。'
            '\n  修复: 必须使用fill_sheet()管线而非手动逐行写入。'
        )
        raise RuntimeError(error_msg)


def _assert_idempotent_clear(ws, data_start_row, total_row, col_map):
    """DT-155: 幂等保护——fill前必须先clear目标区域

    根因: 4-8-6电子设备K列原值3倍(2,559,557 vs 正确862,890)，
    因脚本重复执行追加数据而非覆写。

    实现: 在fill_sheet()写入数据前，先清除data_start_row到total_row之间
    所有金额列的现有数据，确保重复执行不叠加。
    """
    bv_col = col_map.get('账面价值')
    if bv_col is None:
        return  # 无账面价值列的特殊sheet

    cleared = 0
    for row in range(data_start_row, total_row):
        cell = ws.cell(row=row, column=bv_col)
        if not isinstance(cell, MergedCell) and cell.value is not None:
            # DT-214: 增值额/增值率是公式列(=K6-J6)，不应清除
            # 根因: 清除公式列→Phase4公式回填依赖ref_row公式→ref_row也被清→整列公式丢失
            # 只清除数据列，公式列由模板保留/插入行自动下拉
            for semantic in ['账面价值', '评估价值',
                             '序号', '项目及内容', '发生日期', '币种', '汇率', '备注']:
                col = col_map.get(semantic)
                if col and not isinstance(ws.cell(row=row, column=col), MergedCell):
                    ws.cell(row=row, column=col).value = None
            cleared += 1

    if cleared > 0:
        print(f'  [DT-155] 幂等保护: 已清除{cleared}行旧数据')


def _assert_dedup_before_write(data_rows, dedup_key=None):
    """DT-156: 数据源去重——辅助余额表跨表去重

    根因: 5-5应付账款34行重复，因辅助余额表多文件extend不去重。

    实现: 在fill_sheet()写入前检测数据行中是否有重复项，
    重复项按dedup_key标识并告警。
    """
    if not data_rows or not dedup_key:
        return data_rows

    seen = set()
    deduped = []
    duplicates = []

    for row in data_rows:
        key_parts = []
        for k in dedup_key:
            val = row.get(k, row.get('_counterparty', ''))
            if isinstance(val, float):
                val = round(val, 2)
            key_parts.append(str(val))
        key_str = '|'.join(key_parts)

        if key_str in seen:
            duplicates.append(row)
        else:
            seen.add(key_str)
            deduped.append(row)

    if duplicates:
        print(f'  [DT-156] 去重警告: 发现{len(duplicates)}行重复数据(按{dedup_key})，已移除')

    return deduped


def _assert_start_row_from_map(data_start_row, sheet_name):
    """DT-157: data_start_row必须从映射表取，禁止硬编码

    根因: 4-8-6硬编码ds=7，而映射表data_start_row=6，导致表头被覆盖。

    实现: 断言data_start_row来源于_find_header_structure()或sheet_col_map.json，
    而非硬编码值。检测方式：如果data_start_row为常见硬编码值(7)且映射表有不同值，则告警。
    """
    # 检查sheet_col_map.json中的值
    all_maps = _load_sheet_col_map()
    prebuilt = all_maps.get(sheet_name, {})

    if prebuilt:
        map_start_row = None
        # sheet_col_map.json可能存储在sheet的顶层配置中
        for sn, info in _load_sheet_col_map().items():
            if sn == sheet_name and isinstance(info, dict):
                # 尝试从映射文件获取data_start_row
                pass

    # 无法直接检测"硬编码"，但可以通过断言data_start_row > 3来防止表头被覆盖
    assert data_start_row >= 4, (
        f'DT-157 CRITICAL: data_start_row={data_start_row}疑似表头行！'
        f'数据起始行必须在表头行之后。'
    )

    return True


def _assert_per_sheet_reconciliation(ws, sheet_name, data_rows, col_map,
                                      reconcile_target, tolerance=1.0):
    """DT-158: 每sheet填后即时勾稽——不等全部填完再核对

    根因: 5科目差异发现太晚(Phase 4才核对)，如果每sheet填后即时勾稽
    则当场发现。

    实现: fill_sheet()写入完成后，立即sum数据行的账面价值列，
    与科目余额表的对应科目余额比对。差异>tolerance则输出WARNING。
    """
    if reconcile_target is None or not data_rows:
        return  # 无勾稽目标或无数据，跳过

    bv_col = col_map.get('账面价值')
    if bv_col is None:
        return

    # sum数据行的账面价值
    struct = _find_header_structure(ws)
    data_start_row = struct.get('data_start_row', 6)
    total_row = struct.get('total_row')

    if not total_row:
        return

    total_written = 0
    for row in range(data_start_row, total_row):
        cell = ws.cell(row=row, column=bv_col)
        if isinstance(cell, MergedCell):
            continue
        val = cell.value
        if isinstance(val, (int, float)):
            total_written += val

    diff = abs(total_written - abs(reconcile_target))
    if diff > tolerance:
        print(
            f'  [DT-158] ⚠️ 即时勾稽: Sheet {sheet_name} '
            f'写入合计={total_written:,.2f} vs 目标={reconcile_target:,.2f}，'
            f'差额={diff:,.2f}'
        )
        return False
    else:
        print(
            f'  [DT-158] ✅ 即时勾稽通过: Sheet {sheet_name} '
            f'写入合计={total_written:,.2f} vs 目标={reconcile_target:,.2f}'
        )
        return True


def _assert_no_agent_tool_dispatch():
    """DT-159: 禁止下发子任务给Agent tool执行

    根因: 子Agent不遵循任何规则，结果完全失控。
    子Agent无法继承SKILL.md规则上下文、Gate校验、教训库，
    独立执行必然违反所有强约束。

    实现: 本函数在fill_sheet()入口处检查调用栈，
    检测是否从Agent tool子进程调用。如果是，raise RuntimeError。
    同时在SKILL.md中声明红线规则。
    """
    # 检测调用栈中是否有agent/subagent相关标识
    import traceback
    stack = traceback.extract_stack()
    for frame in stack:
        filename = frame.filename.lower()
        # 检测是否从子Agent执行环境调用
        if 'agent_tool' in filename or 'subagent' in filename or 'background_agent' in filename:
            raise RuntimeError(
                'DT-159 CRITICAL: 检测到从子Agent环境调用fill_sheet()！'
                '子Agent不继承规则上下文，禁止下派数据写入任务。'
                '必须由主会话Agent自行执行。'
            )
    return True


def _assert_call_stack_safety():
    """DT-165↑: 调用栈安全检测——确保ws操作通过fill_sheet()管线

    根因: phase4_fix_reconcile.py等独立脚本用裸insert_rows+safe_write
    绕开fill_sheet()，导致DT-113/120/152/162格式规则全部失效
    （3-7预付款项29行数据写入后格式全丢：无边框/12pt/无数字格式）。

    DT-165本意: 现编脚本必须以Skill脚本为前提和基础。
    旧版仅L3文字约束(R级)，Agent可以无视。
    升级为A级: 在fill_sheet()入口检测调用栈，如果调用方绕开
    fill_sheet()直接操作ws对象，给出强WARNING（不crash，因为
    fill_sheet()本身可能被跳过，此时检测不到）。

    本函数的实际作用: 在fill_sheet()被调用时，检测调用方是否
    从同一脚本中调用了裸ws.insert_rows/safe_write等绕过操作。
    如果调用栈中有"非skill脚本的py文件"同时操作了同一个ws，
    给出WARNING提醒。

    注意: 本检测只能覆盖fill_sheet()被调用的场景。
    完全绕开fill_sheet()的脚本(如fill_detail_table.py)无法被
    本检测拦截——需要依赖L2 Gate和Agent自律。
    """
    import traceback
    stack = traceback.extract_stack()

    # 收集调用栈中的所有py文件路径
    caller_files = set()
    for frame in stack:
        if frame.filename.endswith('.py'):
            caller_files.add(frame.filename.lower())

    # 检查是否有项目目录下的脚本(非skill脚本)在调用链中
    # skill脚本路径特征: .workbuddy/skills/
    non_skill_callers = []
    for f in caller_files:
        if '.workbuddy/skills/' not in f and '.workbuddy\\skills\\' not in f:
            # 排除标准库和openpyxl等第三方库
            if 'site-packages' not in f and 'lib\\python' not in f and 'lib/python' not in f:
                # 只关注项目目录下的脚本
                if 'desktop' in f or 'users' in f.lower():
                    non_skill_callers.append(f)

    # 如果检测到非skill脚本在调用链中，输出WARNING
    if non_skill_callers:
        import sys
        for f in non_skill_callers:
            if 'sheet_filler' not in f and 'excel_row_ops' not in f:
                print(
                    f'⚠️ DT-165 WARNING: 检测到非Skill脚本 [{f}] 在调用链中。'
                    f'如果该脚本绕开了fill_sheet()直接操作ws对象，'
                    f'将导致格式/断言/门控全部失效(DT-113/120/152/162)。'
                    f'请确保所有ws操作通过fill_sheet()管线执行。',
                    file=sys.stderr,
                )
    return True
# ============================================================

_RULE_MANIFEST_PATH = None
_MANIFEST_CANDIDATES = [
    _SKILLS_ROOT / 'valuation-detail-table' / 'assets' / 'rule_manifest.json',
    _SCRIPTS_DIR / 'rule_manifest.json',
    _SCRIPTS_DIR / 'assets' / 'rule_manifest.json',
]

for _candidate in _MANIFEST_CANDIDATES:
    if _candidate.exists():
        _RULE_MANIFEST_PATH = _candidate
        break


def rule_coverage_check(phase, execution_log):
    """断言覆盖率检测

    从rule_manifest.json加载该Phase的A级规则，检查执行日志中
    每条规则是否被标记为PASS/FAIL/SKIP。任何A级规则未出现在
    执行日志中则告警"断言缺失"，覆盖率<100%则Gate不通过。

    Args:
        phase: Phase编号（如2）
        execution_log: 执行日志dict {规则ID: 'PASS'/'FAIL'/'SKIP'}

    Returns:
        dict: {
            'total_A_rules': int,
            'covered': int,
            'coverage_rate': float,
            'missing': list,
            'passed': bool
        }
    """
    if _RULE_MANIFEST_PATH is None or not _RULE_MANIFEST_PATH.exists():
        return {
            'total_A_rules': 0,
            'covered': 0,
            'coverage_rate': 1.0,
            'missing': [],
            'passed': True,
            'warning': 'rule_manifest.json未找到，跳过覆盖率检测'
        }

    with open(_RULE_MANIFEST_PATH, 'r', encoding='utf-8') as f:
        manifest = json.load(f)

    # 筛选该Phase的A级规则
    phase_str = str(phase)
    a_rules = {}
    for rule_id, rule_info in manifest.get('rules', {}).items():
        if rule_info.get('level') == 'A':
            rule_phase = str(rule_info.get('phase', ''))
            if rule_phase == 'all' or rule_phase == phase_str:
                a_rules[rule_id] = rule_info

    if not a_rules:
        return {
            'total_A_rules': 0,
            'covered': 0,
            'coverage_rate': 1.0,
            'missing': [],
            'passed': True
        }

    # 检查覆盖率
    covered = 0
    missing = []
    for rule_id in a_rules:
        if rule_id in execution_log:
            covered += 1
        else:
            missing.append(rule_id)

    total = len(a_rules)
    coverage_rate = covered / total if total > 0 else 1.0
    passed = coverage_rate >= 1.0

    if not passed:
        print(
            f'  [断言覆盖率] ⚠️ Phase {phase}: '
            f'{covered}/{total} ({coverage_rate:.0%})，'
            f'缺失规则: {", ".join(missing)}'
        )
    else:
        print(f'  [断言覆盖率] ✅ Phase {phase}: {covered}/{total} (100%)')

    return {
        'total_A_rules': total,
        'covered': covered,
        'coverage_rate': coverage_rate,
        'missing': missing,
        'passed': passed
    }


# ============================================================
# fill_subject() 一键填写入口（v3.51新增）
# ============================================================
# 设计根因：Agent绕开fill_sheet()的核心原因——调用链太长、参数太多、
# 不确定性高、crash风险大。fill_subject()把3步管线封装为1次调用，
# Agent只需传科目编码+project_dir即可。
#
# 使用方式：
#   from sheet_filler import fill_subject
#   result = fill_subject('2202', project_dir=r'C:\项目目录')
#   # 或传入已加载的wb：
#   result = fill_subject('2202', wb=wb, project_dir=r'C:\项目目录')
#
# 内部自动完成：
#   1. 从_dt_cache/subject_sheet_mapping.json获取sheet名称
#   2. 从_dt_cache/subjects_leaf.json获取科目数据
#   3. 自动判断has_journal（检查_dt_cache/journal_counterparties.json）
#   4. 调用prepare_data_rows()组织数据
#   5. 调用fill_sheet()写入
#   6. 返回result（含success/warnings/errors等）

def fill_subject(subject_code, project_dir=None, wb=None, settings=None):
    """一键填写单个科目到评估明细表（v3.51新增）。

    Agent只需传入科目编码和项目目录，内部自动完成：
    - 加载缓存数据（科目余额表/辅助余额表/序时账）
    - 自动推断sheet名称、has_journal等参数
    - 调用prepare_data_rows() + fill_sheet()完整管线
    - 返回result供Agent检查

    Args:
        subject_code: 科目编码（如'2202', '1122', '1001'）
        project_dir: 项目目录路径（含_dt_cache/子目录）。
                     如果为None，需同时提供wb和sheet_name。
        wb: openpyxl workbook对象（可选，不传则自动从project_dir加载）
        settings: 设置信息dict（可选，不传则从缓存加载）

    Returns:
        dict: fill_sheet()的返回值，含success/warnings/errors等。
              额外增加：
              - 'sheet_name': 实际填写的sheet名称
              - 'data_rows_count': 数据行数
              - 'prepare_fixes': prepare_data_rows的自动修复列表

    Raises:
        FileNotFoundError: _dt_cache目录不存在
        ValueError: 科目编码无对应sheet映射
    """
    import json
    from pathlib import Path

    code4 = str(subject_code).strip()[:4]
    code_full = str(subject_code).strip()

    # ---- 1. 确定project_dir和缓存路径 ----
    if project_dir:
        proj = Path(project_dir)
    else:
        raise ValueError('fill_subject()必须提供project_dir参数')

    cache_dir = proj / '_dt_cache'
    if not cache_dir.exists():
        raise FileNotFoundError(
            f'_dt_cache目录不存在: {cache_dir}。'
            f'请先执行Phase 0生成缓存数据。'
        )

    # ---- 2. 加载subject_sheet_mapping.json获取sheet名称 ----
    mapping_file = cache_dir / 'subject_sheet_mapping.json'
    if not mapping_file.exists():
        raise FileNotFoundError(
            f'subject_sheet_mapping.json不存在: {mapping_file}。'
            f'请先执行Phase 1生成科目→Sheet映射。'
        )

    with open(mapping_file, 'r', encoding='utf-8') as f:
        sheet_mapping = json.load(f)

    # 先精确匹配，再4位匹配
    sheet_name = sheet_mapping.get(code_full) or sheet_mapping.get(code4)
    if not sheet_name:
        raise ValueError(
            f'科目编码{code_full}(前4位={code4})无对应Sheet映射。'
            f'已有映射: {list(sheet_mapping.keys())}'
        )

    # ---- 3. 加载workbook（如果未提供）----
    if wb is None:
        # 查找输出文件
        xlsx_files = list(proj.glob('*评估明细表*已填写*.xlsx'))
        if not xlsx_files:
            xlsx_files = list(proj.glob('*评估明细表*.xlsx'))
        if not xlsx_files:
            raise FileNotFoundError(
                f'项目目录下未找到评估明细表文件: {proj}'
            )
        output_path = str(xlsx_files[0])
        wb = openpyxl.load_workbook(output_path)

    # 获取ws对象
    if sheet_name not in wb.sheetnames:
        raise ValueError(
            f'Sheet "{sheet_name}" 不存在于workbook中。'
            f'现有sheets: {wb.sheetnames[:10]}'
        )
    ws = wb[sheet_name]

    # ---- 4. 加载科目数据 ----
    leaf_file = cache_dir / 'subjects_leaf.json'
    if not leaf_file.exists():
        raise FileNotFoundError(f'subjects_leaf.json不存在: {leaf_file}')

    with open(leaf_file, 'r', encoding='utf-8') as f:
        leaf_data = json.load(f)

    # 提取该科目的末级科目数据
    items = []
    leaf_list = leaf_data.get('data', leaf_data) if isinstance(leaf_data, dict) else leaf_data
    for item in leaf_list:
        item_code = str(item.get('code', ''))
        if item_code.startswith(code4) and item.get('is_leaf', True):
            items.append(item)

    if not items:
        return {
            'success': True,
            'sheet_name': sheet_name,
            'data_rows_count': 0,
            'warnings': [f'科目{code4}无末级科目数据，跳过填写'],
            'gate_errors': [],
            'read_back_errors': [],
        }

    # ---- 5. 加载辅助余额表数据（如有）----
    aux_data = None
    aux_file = cache_dir / 'auxiliary_balance.json'
    if aux_file.exists():
        with open(aux_file, 'r', encoding='utf-8') as f:
            aux_all = json.load(f)
        aux_data = aux_all.get(code4) or aux_all.get(code_full)

    # ---- 6. 判断has_journal ----
    has_journal = False
    journal_file = cache_dir / 'journal_counterparties.json'
    if journal_file.exists():
        with open(journal_file, 'r', encoding='utf-8') as f:
            journal_data = json.load(f)
        # 如果journal_data非空且包含该科目的数据
        has_journal = bool(journal_data) and (
            code4 in journal_data or code_full in journal_data
        )

    # ---- 7. 加载设置信息（如有）----
    if settings is None:
        settings_file = cache_dir / 'settings.json'
        if settings_file.exists():
            with open(settings_file, 'r', encoding='utf-8') as f:
                settings = json.load(f)
        else:
            settings = {}

    # ---- 8. 加载坏账准备数据（如有）----
    bad_debt_amount = None
    provision_amount = None
    bd_file = cache_dir / 'bad_debt_data.json'
    if bd_file.exists():
        with open(bd_file, 'r', encoding='utf-8') as f:
            bd_data = json.load(f)
        bd_info = bd_data.get(code4) or bd_data.get(code_full)
        if bd_info:
            bad_debt_amount = bd_info.get('bad_debt')
            provision_amount = bd_info.get('provision')

    # ---- 9. 调用3步管线 ----
    # Step 1: prepare_data_rows
    data_rows, prepare_fixes = prepare_data_rows(
        subject_code=code4,
        aux_data=aux_data,
        kmye_data=items,
        subject_name=items[0].get('name', '') if items else '',
        has_journal=has_journal,
        has_foreign_currency=False,
    )

    # Step 2: fill_sheet
    result = fill_sheet(
        ws=ws,
        sheet_name=sheet_name,
        data_rows=(data_rows, prepare_fixes),  # v3.51元组格式
        settings=settings,
        wb=wb,
        has_journal=has_journal,
        has_foreign_currency=False,
        bad_debt_amount=bad_debt_amount,
        provision_amount=provision_amount,
        subject_code=code4,
    )

    # 附加额外信息
    result['sheet_name'] = sheet_name
    result['data_rows_count'] = len(data_rows)
    result['prepare_fixes'] = prepare_fixes

    # Step 3: 保存workbook
    if project_dir:
        # 查找输出路径
        xlsx_files = list(Path(project_dir).glob('*评估明细表*已填写*.xlsx'))
        if xlsx_files:
            try:
                wb.save(str(xlsx_files[0]))
                result['saved_to'] = str(xlsx_files[0])
            except PermissionError:
                result['warnings'].append(
                    f'⚠️ 文件被占用无法保存: {xlsx_files[0]}。'
                    f'请关闭Excel后手动保存。'
                )

    return result


# ============================================================
# DT-176: finalize_workbook() — 所有科目填完后的收尾入口
# 自动调用：hide_empty_sheets + 输出格式Gate + 保存
# ============================================================

def finalize_workbook(xlsx_path, dry_run=False, col_map_data=None):
    """DT-176: 评估明细表收尾入口——所有科目填写完成后必须调用。

    自动执行：
    1. 隐藏空白明细表（DT-20）+ 辅助表（DT-23）+ 辅汇总表（DT-61）
    2. 输出格式完整性检查（G-DT175，DT-125↑/DT-151↑等）
    3. 空白明细表未隐藏检测（DT-20兜底）
    4. 保存workbook

    这个函数的存在意义：Agent经常跳过Phase 5/6收尾步骤（隐藏空表、格式检查），
    因为这些是"填完数据后的收尾工作"，Agent认为"数据填完=完工"。
    将收尾步骤封装为一个函数调用，消除"忘记执行"的问题。

    Args:
        xlsx_path: 评估明细表文件路径（已填写数据的版本）
        dry_run: 仅扫描不修改（用于预览）
        col_map_data: sheet_col_map.json数据（可选，用于精确定位列）

    Returns:
        dict: {
            'success': bool,
            'hide_report': dict,      # hide_empty_sheets()返回值
            'format_check': dict,      # validate_output_format_integrity()返回值
            'unhidden_empty': list,    # 未隐藏的空白明细表清单
            'saved': bool,
            'warnings': list,
            'criticals': list,
        }
    """
    import openpyxl
    from pathlib import Path

    filepath = Path(xlsx_path)
    if not filepath.exists():
        raise FileNotFoundError(f'文件不存在: {filepath}')

    result = {
        'success': True,
        'hide_report': None,
        'format_check': None,
        'unhidden_empty': [],
        'saved': False,
        'warnings': [],
        'criticals': [],
    }

    # ---- Step 1: 隐藏空白Sheet（DT-20/DT-23/DT-61/DT-110） ----
    try:
        from hide_empty_sheets import hide_empty_sheets, format_report
        hide_result = hide_empty_sheets(str(filepath), dry_run=dry_run)
        result['hide_report'] = hide_result

        # 输出可读报告
        report_text = format_report(hide_result)
        _execution_log['DT-176-hide'] = 'PASS'
    except ImportError:
        result['warnings'].append(
            'hide_empty_sheets.py不可用，跳过空表隐藏。'
            '请手动执行: python hide_empty_sheets.py <xlsx_path>'
        )
        _execution_log['DT-176-hide'] = 'SKIP'
    except Exception as e:
        result['warnings'].append(f'隐藏空表失败: {e}')
        _execution_log['DT-176-hide'] = f'ERROR: {e}'

    # ---- Step 2: 输出格式完整性检查（G-DT175） ----
    try:
        wb = openpyxl.load_workbook(str(filepath))
    except Exception as e:
        result['criticals'].append(f'无法打开文件: {e}')
        result['success'] = False
        return result

    try:
        from gate_validator import validate_output_format_integrity
        format_result = validate_output_format_integrity(wb, col_map_data=col_map_data)
        result['format_check'] = format_result

        if not format_result.get('pass', True):
            result['criticals'].extend(format_result.get('criticals', []))
            result['warnings'].extend(format_result.get('warnings', []))
            _execution_log['DT-176-format'] = 'FAIL' if format_result.get('criticals') else 'WARN'
        else:
            _execution_log['DT-176-format'] = 'PASS'
    except ImportError:
        result['warnings'].append('gate_validator.py不可用，跳过格式检查')
        _execution_log['DT-176-format'] = 'SKIP'

    # ---- Step 3: 空白明细表未隐藏检测（DT-20兜底） ----
    try:
        from hide_empty_sheets import check_sheet_empty, is_detail_sheet, is_structure_sheet
        unhidden_empty = []
        for sname in wb.sheetnames:
            ws = wb[sname]
            if ws.sheet_state == 'hidden':
                continue  # 已隐藏，跳过
            if not is_detail_sheet(sname):
                continue  # 非明细表，跳过
            if is_structure_sheet(sname):
                continue  # 汇总/结构表，跳过

            check = check_sheet_empty(ws, sname, xlsx_path=str(filepath))
            if check.get('is_empty'):
                unhidden_empty.append({
                    'sheet_name': sname,
                    'reason': check.get('reason', ''),
                    'book_value': str(check.get('book_resolved')),
                    'eval_value': str(check.get('eval_resolved')),
                })

        if unhidden_empty:
            result['unhidden_empty'] = unhidden_empty
            result['criticals'].append(
                f'DT-20 CRITICAL: 有{len(unhidden_empty)}个空白明细表未隐藏！'
                f'Sheet: {[u["sheet_name"] for u in unhidden_empty]}'
            )
            _execution_log['DT-176-unhidden'] = 'FAIL'
        else:
            _execution_log['DT-176-unhidden'] = 'PASS'
    except ImportError:
        _execution_log['DT-176-unhidden'] = 'SKIP'

    # ---- Step 4: 保存 ----
    if not dry_run:
        try:
            wb.save(str(filepath))
            result['saved'] = True
        except PermissionError:
            result['warnings'].append(
                f'⚠️ 文件被占用无法保存: {filepath}。请关闭Excel后重新执行。'
            )
    else:
        result['warnings'].append('DRY-RUN模式——仅扫描，未修改文件')

    wb.close()

    # ---- 汇总判定 ----
    if result['criticals']:
        result['success'] = False

    return result


# ============================================================
# CLI入口（用于测试）
# ============================================================

if __name__ == '__main__':
    import argparse
    import openpyxl

    parser = argparse.ArgumentParser(description='sheet_filler.py v1.0 — Agent唯一允许调用的明细表写入接口')
    parser.add_argument('--test-col-map', action='store_true', help='测试列映射构建')
    parser.add_argument('--test-industry', action='store_true', help='测试行业映射')
    parser.add_argument('--xlsx-path', help='Excel文件路径')
    parser.add_argument('--sheet', help='工作表名称')
    parser.add_argument('--industry', default='房地产', help='行业类型')

    args = parser.parse_args()

    if args.test_industry:
        # 测试行业映射
        test_codes = ['5002', '5001', '1122', '222106', '1811']
        for code in test_codes:
            sid = get_sheet_id_for_subject(code, args.industry)
            biz = infer_business_content(code, '测试公司', f'科目{code}')
            print(f'  {code} → Sheet={sid}, 业务内容="{biz}"')

    elif args.test_col_map and args.xlsx_path:
        # 测试列映射
        wb = openpyxl.load_workbook(args.xlsx_path)
        for sname in wb.sheetnames:
            ws = wb[sname]
            struct = _find_header_structure(ws)
            if struct.get('header_row'):
                col_map = _build_col_map(ws, struct['header_row'], struct.get('sub_header_row'))
                print(f'\n{sname}:')
                for semantic, col in sorted(col_map.items(), key=lambda x: x[1]):
                    print(f'  {semantic}: 列{col}({get_column_letter(col)})')
        wb.close()

    else:
        parser.print_help()

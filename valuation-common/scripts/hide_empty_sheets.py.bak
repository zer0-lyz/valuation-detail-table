#!/usr/bin/env python3
"""
hide_empty_sheets.py — 评估明细表空白Sheet自动隐藏工具

功能：按DT-20/DT-23/DT-110规则，自动扫描评估明细表中的空白Sheet和辅助表并隐藏。

判定标准（DT-20精确化）：
  空白Sheet = A列"合计1"所在行的账面价值列AND评估价值列均为0或blank

辅助表（DT-23，始终隐藏）：
  设置、0-其他方法结论、设定信息

辅汇总表（DT-61，始终隐藏）：
  3-辅-流动资产汇总、3-9-辅-存货汇总、8-减值准备汇总表、9-非财务信息汇总表

用法：
  python hide_empty_sheets.py <xlsx_path> [--dry-run] [--output-report <path>]

参数：
  xlsx_path       评估明细表文件路径
  --dry-run       仅扫描不修改，输出隐藏清单预览
  --output-report 隐藏清单输出路径（默认stdout）

退出码：
  0 = 成功（或dry-run完成）
  1 = 错误
"""

import argparse
import json
import sys
from pathlib import Path

try:
    import openpyxl
except ImportError:
    print("ERROR: openpyxl未安装，请运行: pip install openpyxl")
    sys.exit(1)


# ===== sheet_col_map.json加载（DT-212：双行表头列位修正） =====

def _find_sheet_col_map_path() -> "Path | None":
    """查找sheet_col_map.json预生成映射文件路径"""
    _SKILLS_ROOT = Path.home() / '.workbuddy' / 'skills'
    _SCRIPTS_DIR = Path(__file__).resolve().parent
    candidates = [
        _SKILLS_ROOT / 'valuation-detail-table' / 'assets' / 'sheet_col_map.json',
        _SCRIPTS_DIR.parent / 'assets' / 'sheet_col_map.json',
        _SCRIPTS_DIR / 'sheet_col_map.json',
        _SCRIPTS_DIR / 'assets' / 'sheet_col_map.json',
    ]
    for c in candidates:
        if c.exists():
            return c
    return None


_COL_MAP_CACHE = None


def _load_sheet_col_map() -> dict:
    """加载sheet_col_map.json，返回 {sheet_name: col_map_dict}"""
    global _COL_MAP_CACHE
    if _COL_MAP_CACHE is not None:
        return _COL_MAP_CACHE

    map_path = _find_sheet_col_map_path()
    if map_path is None:
        _COL_MAP_CACHE = {}
        return _COL_MAP_CACHE

    try:
        with open(map_path, 'r', encoding='utf-8') as f:
            data = json.load(f)
        _COL_MAP_CACHE = {}
        for sn, info in data.get('sheets', {}).items():
            _COL_MAP_CACHE[sn] = info.get('col_map', {})
        return _COL_MAP_CACHE
    except Exception:
        _COL_MAP_CACHE = {}
        return _COL_MAP_CACHE


def _get_col_map_for_sheet(sheet_name: str) -> dict:
    """获取指定Sheet的列映射（book_value/assessed_value列号）"""
    all_maps = _load_sheet_col_map()
    if sheet_name in all_maps:
        return all_maps[sheet_name]
    # 模糊匹配
    import re
    clean_name = re.sub(r'[（(].+?[）)]', '', sheet_name).strip()
    for cached_name, cmap in all_maps.items():
        cached_clean = re.sub(r'[（(].+?[）)]', '', cached_name).strip()
        if clean_name == cached_clean:
            return cmap
    return {}


